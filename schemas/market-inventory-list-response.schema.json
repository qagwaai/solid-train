{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "market-inventory-list-response",
  "type": "object",
  "required": ["success", "message", "inventory", "total", "offset", "limit", "correlationId", "requestIdentity"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Echo of the request correlationId."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "playerName": { "type": "string" },
    "marketId": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "marketName": { "type": "string" },
    "reason": {
      "type": "string",
      "description": "Stable machine-readable failure reason when success is false."
    },
    "inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "itemId",
          "itemType",
          "displayName",
          "rarity",
          "stock",
          "maxStock",
          "restockPerInterval",
          "marketCanBuy",
          "marketCanSell"
        ],
        "properties": {
          "itemId": { "type": "string" },
          "itemType": { "type": "string" },
          "displayName": { "type": "string" },
          "rarity": { "type": "string" },
          "stock": { "type": "integer", "minimum": 0 },
          "maxStock": { "type": "integer", "minimum": 0 },
          "restockPerInterval": { "type": "integer", "minimum": 0 },
          "marketCanBuy": { "type": "boolean" },
          "marketCanSell": { "type": "boolean" }
        }
      }
    },
    "total": { "type": "integer" },
    "offset": { "type": "integer" },
    "limit": { "type": "integer" },
    "asOf": { "type": "string", "format": "date-time" }
  }
}
