{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "market-inventory-list-response",
  "type": "object",
  "required": ["success", "message", "playerName", "marketId", "solarSystemId", "marketName", "inventory", "total", "offset", "limit", "asOf"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "playerName": { "type": "string" },
    "marketId": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "marketName": { "type": "string" },
    "inventory": { "type": "array" },
    "total": { "type": "integer" },
    "offset": { "type": "integer" },
    "limit": { "type": "integer" },
    "asOf": { "type": "string", "format": "date-time" }
  }
}
