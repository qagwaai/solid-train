{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "launch-item-request",
  "type": "object",
  "required": [
    "playerName",
    "sessionKey",
    "correlationId",
    "requestIdentity",
    "characterId",
    "shipId",
    "targetCelestialBodyId",
    "hotkey",
    "itemId",
    "itemType"
  ],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Client-generated UUID v4 used to correlate each request/response pair."
    },
    "requestIdentity": {
      "type": "object",
      "description": "Identity block echoed by the backend so clients can demultiplex concurrent responses safely.",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "characterId": { "type": "string" },
    "shipId": { "type": "string" },
    "targetCelestialBodyId": { "type": "string" },
    "hotkey": {
      "type": "integer",
      "enum": [1, 2, 3, 4, 5],
      "description": "Launch slot hotkey. Must be one of the supported launch hotkeys 1 through 5."
    },
    "itemId": { "type": "string" },
    "itemType": {
      "type": "string",
      "description": "Expected persisted item type for the launched item. Must match the stored item record."
    }
  }
}
