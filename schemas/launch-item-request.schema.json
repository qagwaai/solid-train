{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "launch-item-request",
  "type": "object",
  "required": ["playerName", "sessionKey", "characterId", "shipId", "targetCelestialBodyId", "hotkey", "itemId", "itemType"],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "characterId": { "type": "string" },
    "shipId": { "type": "string" },
    "targetCelestialBodyId": { "type": "string" },
    "hotkey": {
      "type": "integer",
      "enum": [1, 2, 3, 4, 5],
      "description": "Launch slot hotkey. Must be one of the supported launch hotkeys 1 through 5."
    },
    "itemId": { "type": "string" },
    "itemType": {
      "type": "string",
      "description": "Expected persisted item type for the launched item. Must match the stored item record."
    }
  }
}
