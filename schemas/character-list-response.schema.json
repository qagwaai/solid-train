{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "character-list-response",
  "type": "object",
  "required": ["success", "message", "playerName", "characters"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "playerName": { "type": "string" },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "characterName", "createdAt", "credits", "creditLedger", "ships", "inGame", "gameJoinedAt", "gameLastMessageReceivedAt"],
        "properties": {
          "id": { "type": "string" },
          "characterName": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "credits": { "type": "number" },
          "creditLedger": { "type": "array" },
          "ships": { "type": "array" },
          "inGame": { "type": "boolean" },
          "gameJoinedAt": { "type": "string", "format": "date-time" },
          "gameLastMessageReceivedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
