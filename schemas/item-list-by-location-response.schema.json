{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "item-list-by-location-response",
  "type": "object",
  "required": ["success", "message", "playerName", "solarSystemId", "items"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "playerName": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "positionKm": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "required": ["x", "y", "z"]
    },
    "distanceKm": { "type": "number" },
    "itemType": { "type": ["string", "null"] },
    "items": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "./item.schema.json" },
          {
            "type": "object",
            "properties": {
              "distanceKm": { "type": "number" }
            },
            "required": ["distanceKm"]
          }
        ]
      }
    }
  }
}
