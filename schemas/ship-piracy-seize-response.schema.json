{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ship-piracy-seize-response",
  "type": "object",
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "reason": {
      "type": "string",
      "enum": [
        "INVALID_SESSION",
        "OWNERSHIP_VALIDATION_FAILED",
        "PIRACY_SEIZE_INVALID_TARGET",
        "SHIP_NOT_FOUND"
      ]
    },
    "correlationId": { "type": "string" },
    "shipId": { "type": "string" },
    "seizingOwner": {
      "type": "object",
      "properties": {
        "ownerType": { "type": "string" },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "previousOwner": {
      "type": "object",
      "properties": {
        "ownerType": { "type": "string" },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "seizedAt": { "type": "string" }
  },
  "additionalProperties": true
}
