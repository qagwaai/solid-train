{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "context-routing-response",
  "type": "object",
  "required": ["success", "message", "playerName", "source", "destination", "route", "correlationId", "requestIdentity"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Echo of the request correlationId."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "playerName": { "type": "string" },
    "source": { "type": "string" },
    "destination": { "type": "string" },
    "route": { "type": "array" },
    "requestId": { "type": "string" }
  }
}
