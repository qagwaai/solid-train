{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "celestial-body-list-request",
  "type": "object",
  "required": ["playerName", "sessionKey", "solarSystemId"],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "positionKm": {
      "type": "object",
      "description": "Required only for radius queries. Omit together with distanceKm for whole-system listing mode.",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "required": ["x", "y", "z"]
    },
    "distanceKm": {
      "type": "number",
      "minimum": 0,
      "description": "Required only for radius queries. Omit together with positionKm for whole-system listing mode."
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "description": "Optional positive result limit."
    },
    "states": {
      "type": "array",
      "items": { "type": "string", "enum": ["unscanned", "active", "destroyed"] },
      "description": "Optional canonical state filter."
    },
    "createdByCharacterId": { "type": "string" },
    "missionId": { "type": "string" }
  }
}
