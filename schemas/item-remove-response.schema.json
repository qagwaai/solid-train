{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "item-remove-response",
  "type": "object",
  "required": [
    "success",
    "message",
    "correlationId",
    "requestIdentity",
    "playerName",
    "characterId",
    "shipId",
    "itemId",
    "itemType"
  ],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Echo of the request correlationId."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "playerName": { "type": "string" },
    "characterId": { "type": "string" },
    "shipId": { "type": "string" },
    "itemId": { "type": "string" },
    "itemType": { "type": "string" },
    "item": {
      "$ref": "./item.schema.json",
      "description": "Present on successful item-remove responses."
    }
  }
}
