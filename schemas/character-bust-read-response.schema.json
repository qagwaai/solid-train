{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "character-bust-read-response",
  "description": "Response containing the current stored bust descriptor for a playable character.",
  "type": "object",
  "required": [
    "success",
    "message",
    "correlationId",
    "requestIdentity",
    "playerName",
    "characterId",
    "descriptor"
  ],
  "additionalProperties": false,
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Echo of the request correlationId."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "playerName": { "type": "string" },
    "characterId": {
      "type": "string",
      "description": "The character whose bust was read."
    },
    "descriptor": {
      "$ref": "./bust-descriptor.schema.json",
      "description": "The normalized stored bust descriptor."
    }
  }
}
