{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "character-add-response",
  "type": "object",
  "required": ["success", "message", "playerName", "characterName", "characterId", "correlationId", "requestIdentity"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Echo of the request correlationId."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "playerName": { "type": "string" },
    "characterName": { "type": "string" },
    "characterId": { "type": "string" }
  }
}
