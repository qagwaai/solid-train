{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "market-list-by-location-response",
  "type": "object",
  "required": ["success", "message", "playerName", "solarSystemId", "positionKm", "distanceAu", "markets"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "playerName": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "positionKm": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "required": ["x", "y", "z"]
    },
    "distanceAu": { "type": "number" },
    "markets": { "type": "array" }
  }
}
