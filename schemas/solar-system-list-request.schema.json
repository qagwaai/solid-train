{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "solar-system-list-request",
  "type": "object",
  "required": ["playerName", "sessionKey"],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "source": { "type": "string" },
    "maxDistanceParsec": { "type": "number" },
    "search": { "type": "string" },
    "limit": { "type": "integer" },
    "requestId": { "type": "string" }
  }
}
