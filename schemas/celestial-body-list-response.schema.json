{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "celestial-body-list-response",
  "type": "object",
  "required": ["success", "message", "playerName", "solarSystemId", "positionKm", "distanceKm", "celestialBodies"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "playerName": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "positionKm": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      },
      "required": ["x", "y", "z"]
    },
    "distanceKm": { "type": "number" },
    "celestialBodies": { "type": "array" }
  }
}
