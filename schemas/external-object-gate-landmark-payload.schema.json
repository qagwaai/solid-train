{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "external-object-gate-landmark-payload",
  "type": "object",
  "required": ["schemaVersion", "gates"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "sw-13-m0-v1",
      "description": "Pinned SW-13 schema version for jump gate landmark payloads."
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["descriptor", "approachMetadata"],
        "properties": {
          "descriptor": {
            "$ref": "./external-object-descriptor.schema.json"
          },
          "approachMetadata": {
            "$ref": "#/definitions/gateApproachMetadata"
          }
        },
        "additionalProperties": false
      },
      "description": "Deterministic gate landmark inventory sorted by descriptor descriptorId with bounded canonical gate family count."
    }
  },
  "definitions": {
    "gateApproachMetadata": {
      "type": "object",
      "required": [
        "approachCue",
        "landmarkFraming",
        "navBeaconCue",
        "hazardCue",
        "warningEscalation",
        "recommendedStandOffKm",
        "approachWindowKm"
      ],
      "properties": {
        "approachCue": {
          "type": "string",
          "enum": ["direct-centerline", "offset-spiral", "vector-handoff"],
          "description": "Navigation approach cue used to maintain unmistakable gate approach semantics."
        },
        "landmarkFraming": {
          "type": "string",
          "enum": ["full-ring", "segmented-arch", "spindle-column"],
          "description": "Camera-facing framing cue used for long-range landmark readability."
        },
        "navBeaconCue": {
          "type": "string",
          "enum": ["continuous", "pulse", "triplet"],
          "description": "Beacon rhythm cue used by navigation-facing approach overlays."
        },
        "hazardCue": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Approach hazard cue for navigation decision support." 
        },
        "warningEscalation": {
          "type": "string",
          "enum": ["none", "required"],
          "description": "Mandatory warning escalation policy for route-smoke evidence and approach UX assertions."
        },
        "recommendedStandOffKm": {
          "type": "number",
          "minimum": 1,
          "description": "Recommended standoff distance before committing to the gate approach corridor."
        },
        "approachWindowKm": {
          "type": "object",
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "number", "minimum": 1 },
            "max": { "type": "number", "minimum": 1 }
          },
          "additionalProperties": false,
          "description": "Window bounds for cue-stable approach behavior."
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "schemaVersion": "sw-13-m0-v1",
      "gates": [
        {
          "descriptor": {
            "descriptorId": "gates-ring-gate",
            "schemaVersion": "sw-13-m0-v1",
            "domain": "gates",
            "objectFamily": "ring-gate",
            "roleCue": "navigation",
            "factionCue": "consortium",
            "fallbackTier": "hero",
            "displayLabel": "Ring Gate Landmark",
            "silhouetteProfile": "ring",
            "materialProfile": "infrastructure",
            "emissiveProfile": "navigation"
          },
          "approachMetadata": {
            "approachCue": "direct-centerline",
            "landmarkFraming": "full-ring",
            "navBeaconCue": "continuous",
            "hazardCue": "low",
            "warningEscalation": "none",
            "recommendedStandOffKm": 1400,
            "approachWindowKm": {
              "min": 1000,
              "max": 2200
            }
          }
        }
      ]
    }
  ],
  "additionalProperties": false
}
