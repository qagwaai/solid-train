{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ship-upsert-response",
  "type": "object",
  "required": ["success", "message", "playerName", "characterId"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "playerName": { "type": "string" },
    "characterId": { "type": "string" },
    "ship": {
      "type": "object",
      "description": "Present on successful ship upsert responses.",
      "additionalProperties": true
    }
  }
}
