{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ship-upsert-response",
  "type": "object",
  "required": ["success", "message", "playerName", "characterId"],
  "properties": {
    "success": { "type": "boolean" },
    "reason": {
      "type": "string",
      "enum": [
        "OWNERSHIP_VALIDATION_FAILED",
        "OWNERSHIP_CONFLICT",
        "SHIP_OWNERSHIP_MISMATCH",
        "OWNERSHIP_CLAIM_TOKEN_REQUIRED"
      ]
    },
    "message": { "type": "string" },
    "playerName": { "type": "string" },
    "characterId": { "type": "string" },
    "ship": {
      "type": "object",
      "description": "Present on successful ship upsert responses.",
      "additionalProperties": true
    }
  }
}
