{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ship-transfer-response",
  "type": "object",
  "required": ["success", "message"],
  "properties": {
    "success": { "type": "boolean" },
    "reason": {
      "type": "string",
      "enum": [
        "INVALID_SESSION",
        "SHIP_ID_REQUIRED",
        "SHIP_NOT_FOUND",
        "SHIP_TRANSFER_FORBIDDEN",
        "OWNERSHIP_VALIDATION_FAILED"
      ]
    },
    "message": { "type": "string" },
    "shipId": { "type": "string" },
    "ships": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Present on INVALID_SESSION responses for compatibility with shared error payload shape."
    },
    "fromOwner": {
      "type": "object",
      "properties": {
        "ownerType": { "type": "string" },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "toOwner": {
      "type": "object",
      "properties": {
        "ownerType": { "type": "string" },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "ownership": {
      "type": "object",
      "properties": {
        "ownerType": { "type": "string" },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  }
}
