{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "character-bust-read-request",
  "description": "Request to read the current bust descriptor for a playable character.",
  "type": "object",
  "required": [
    "playerName",
    "sessionKey",
    "correlationId",
    "requestIdentity",
    "characterId"
  ],
  "additionalProperties": false,
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Client-generated UUID v4 used to correlate each request/response pair."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "characterId": {
      "type": "string",
      "description": "Identifies the playable character whose bust is being read."
    }
  }
}
