{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "market-ledger-list-response",
  "type": "object",
  "required": ["success", "message", "entries", "total", "offset", "limit", "correlationId", "requestIdentity"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Echo of the request correlationId."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "playerName": { "type": "string" },
    "marketId": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "reason": {
      "type": "string",
      "description": "Stable machine-readable failure reason when success is false."
    },
    "requestId": {
      "type": ["string", "null"],
      "description": "Echoed caller correlation id when one was provided on the request."
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "transactionId",
          "requestId",
          "characterId",
          "itemId",
          "direction",
          "quantity",
          "unitPrice",
          "totalPrice",
          "timestamp",
          "reversalOfTransactionId"
        ],
        "properties": {
          "transactionId": { "type": "string" },
          "requestId": { "type": ["string", "null"] },
          "characterId": { "type": "string" },
          "itemId": { "type": "string" },
          "direction": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 },
          "unitPrice": { "type": "number" },
          "totalPrice": { "type": "number" },
          "timestamp": { "type": "string", "format": "date-time" },
          "reversalOfTransactionId": { "type": ["string", "null"] }
        }
      }
    },
    "total": { "type": "integer" },
    "offset": { "type": "integer" },
    "limit": { "type": "integer" }
  }
}
