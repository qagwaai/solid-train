{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "item-list-by-container-response",
  "type": "object",
  "required": ["success", "message", "playerName", "containerType", "containerId", "items"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "playerName": { "type": "string" },
    "containerType": { "type": "string", "enum": ["ship", "market"] },
    "containerId": { "type": "string" },
    "items": {
      "type": "array",
      "items": { "$ref": "./item.schema.json" }
    }
  }
}
