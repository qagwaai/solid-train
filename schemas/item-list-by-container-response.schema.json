{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "item-list-by-container-response",
  "type": "object",
  "required": ["success", "message", "playerName", "containerType", "containerId", "items", "correlationId", "requestIdentity"],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Echo of the request correlationId."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "playerName": { "type": "string" },
    "containerType": { "type": "string", "enum": ["ship", "market"] },
    "containerId": { "type": "string" },
    "items": {
      "type": "array",
      "items": { "$ref": "./item.schema.json" }
    }
  }
}
