{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "character-add-request",
  "type": "object",
  "required": ["playerName", "sessionKey", "correlationId", "requestIdentity", "characterName"],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Client-generated UUID v4 used to correlate each request/response pair."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "characterName": { "type": "string" }
  }
}
