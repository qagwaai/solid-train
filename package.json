{
  "name": "solid-train",
  "version": "1.0.0",
  "description": "Simple Socket.IO server with Node.js best practices",
  "main": "src/server.js",
  "scripts": {
    "test": "npx --yes @apidevtools/swagger-cli validate api/openapi.yaml && node --test",
    "start": "cross-env MONGODB_URI=mongodb://localhost:27017/solid-train node src/server.js",
    "start:dev": "cross-env LOG_LEVEL=debug MONGODB_URI=mongodb://localhost:27017/solid-train node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.checkjs.json",
    "contract:artifact": "node scripts/sw08/generate-contract-artifact.js --out api/artifacts/contracts/contract-artifact.json",
    "contract:lint:item-types": "node --test test/launch-item-contract-hardening.test.js",
    "contract:lint:mission-status": "node --test test/sw01-mission-status-contract-hardening.test.js",
    "contract:lint:sw13-descriptor": "node --test test/sw13-external-object-contract-hardening.test.js test/sw13-external-object-descriptor-m2-ship-station.test.js test/sw13-external-object-descriptor-m3-gate-landmark.test.js test/sw13-descriptor-size-consistency-m4.test.js",
    "contract:review:sw13:size": "node scripts/sw13/review-descriptor-size-consistency.js --report api/artifacts/contracts/sw13-m4-size-consistency-report.json",
    "contract:review:sw13:size:parity": "node scripts/sw13/assert-size-review-parity.js",
    "contract:lint:mission-status:negative-fixture": "node scripts/sw01/assert-invalid-mission-status-fixture.js",
    "contract:drift": "node scripts/sw08/check-contract-drift.js --baseline api/artifacts/contracts/baseline-contract-artifact.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/drift-report.json --mode report-only",
    "contract:gate": "npm run contract:artifact && npm run contract:lint:item-types && npm run contract:lint:mission-status && npm run contract:gate:hard",
    "contract:fixture-check": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw08/drift-old.json --current test/fixtures/sw08/drift-new.json --report api/artifacts/contracts/drift-fixture-report.json --mode report-only",
    "contract:gate:soft": "node scripts/sw08/check-contract-drift.js --baseline api/artifacts/contracts/baseline-contract-artifact.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/drift-report.json --mode soft-fail",
    "contract:gate:soft:approved": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw08/drift-old.json --current test/fixtures/sw08/drift-new.json --report api/artifacts/contracts/drift-approved-report.json --mode soft-fail --exception test/fixtures/sw08/approved-exception.json",
    "contract:compat-check": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw08/compat-old.json --current test/fixtures/sw08/compat-new.json --report api/artifacts/contracts/compat-report.json --mode soft-fail",
    "contract:compat-check:sw01": "node scripts/sw01/run-cross-repo-gate.js --baseline test/fixtures/sw01/m3/nova-consumer-inventory-aligned.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw01-m3-alignment-report.json --mode hard-fail",
    "contract:compat-check:sw13": "node scripts/sw13/run-cross-repo-gate.js --baseline test/fixtures/sw13/m3/nova-consumer-inventory-aligned.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw13-m3-alignment-report.json --mode hard-fail",
    "contract:preflight:sw01:nova": "node scripts/sw01/run-cross-repo-gate.js --baseline test/fixtures/sw01/m3/nova-consumer-inventory-aligned.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw01-m4-nova-preflight-report.json --mode hard-fail",
    "contract:preflight:sw13:nova": "node scripts/sw13/run-cross-repo-gate.js --baseline test/fixtures/sw13/m3/nova-consumer-inventory-aligned.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw13-m4-nova-preflight-report.json --mode hard-fail",
    "contract:compat-drift:sw01:enum": "node scripts/sw01/run-cross-repo-gate.js --baseline test/fixtures/sw01/m3/nova-consumer-inventory-aligned.json --current test/fixtures/sw01/m3/mission-list-drift-enum-mismatch.json --report api/artifacts/contracts/sw01-m3-drift-enum-report.json --mode hard-fail",
    "contract:compat-drift:sw01:unsupported-status": "node scripts/sw01/run-cross-repo-gate.js --baseline test/fixtures/sw01/m3/nova-consumer-inventory-legacy-status.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw01-m3-drift-unsupported-status-report.json --mode hard-fail",
    "contract:compat-drift:sw01:shape": "node scripts/sw01/run-cross-repo-gate.js --baseline test/fixtures/sw01/m3/nova-consumer-inventory-aligned.json --current test/fixtures/sw01/m3/mission-list-drift-shape-mismatch.json --report api/artifacts/contracts/sw01-m3-drift-shape-report.json --mode hard-fail",
    "contract:compat-drift:sw13:enum": "node scripts/sw13/run-cross-repo-gate.js --baseline test/fixtures/sw13/m3/nova-consumer-inventory-aligned.json --current test/fixtures/sw13/m3/external-object-descriptor-drift-enum-mismatch.json --report api/artifacts/contracts/sw13-m3-drift-enum-report.json --mode hard-fail",
    "contract:compat-drift:sw13:unsupported-domain": "node scripts/sw13/run-cross-repo-gate.js --baseline test/fixtures/sw13/m3/nova-consumer-inventory-legacy-domain.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw13-m3-drift-unsupported-domain-report.json --mode hard-fail",
    "contract:compat-drift:sw13:shape": "node scripts/sw13/run-cross-repo-gate.js --baseline test/fixtures/sw13/m3/nova-consumer-inventory-aligned.json --current test/fixtures/sw13/m3/external-object-descriptor-drift-shape-mismatch.json --report api/artifacts/contracts/sw13-m3-drift-shape-report.json --mode hard-fail",
    "contract:gate:sw01:forge": "npm run contract:artifact && npm run contract:lint:mission-status && node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw01/m3/nova-consumer-inventory-aligned.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw01-m4-forge-pass-report.json --mode hard-fail",
    "contract:gate:sw13:forge": "npm run contract:artifact && npm run contract:review:sw13:size && npm run contract:review:sw13:size:parity && npm run contract:lint:sw13-descriptor && node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw13/m3/nova-consumer-inventory-aligned.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw13-m4-forge-pass-report.json --mode hard-fail",
    "contract:gate:sw01:forge:drift:enum": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw01/m3/nova-consumer-inventory-aligned.json --current test/fixtures/sw01/m3/mission-list-drift-enum-mismatch.json --report api/artifacts/contracts/sw01-m4-forge-drift-enum-report.json --mode hard-fail",
    "contract:gate:sw01:forge:drift:unsupported-status": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw01/m3/nova-consumer-inventory-legacy-status.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw01-m4-forge-drift-unsupported-status-report.json --mode hard-fail",
    "contract:gate:sw01:forge:drift:shape": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw01/m3/nova-consumer-inventory-aligned.json --current test/fixtures/sw01/m3/mission-list-drift-shape-mismatch.json --report api/artifacts/contracts/sw01-m4-forge-drift-shape-report.json --mode hard-fail",
    "contract:gate:sw13:forge:drift:enum": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw13/m3/nova-consumer-inventory-aligned.json --current test/fixtures/sw13/m3/external-object-descriptor-drift-enum-mismatch.json --report api/artifacts/contracts/sw13-m4-forge-drift-enum-report.json --mode hard-fail",
    "contract:gate:sw13:forge:drift:unsupported-domain": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw13/m3/nova-consumer-inventory-legacy-domain.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/sw13-m4-forge-drift-unsupported-domain-report.json --mode hard-fail",
    "contract:gate:sw13:forge:drift:shape": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw13/m3/nova-consumer-inventory-aligned.json --current test/fixtures/sw13/m3/external-object-descriptor-drift-shape-mismatch.json --report api/artifacts/contracts/sw13-m4-forge-drift-shape-report.json --mode hard-fail",
    "contract:gate:sw01:dual": "npm run contract:gate:sw01:forge && npm run contract:preflight:sw01:nova",
    "contract:gate:sw13:dual": "npm run contract:gate:sw13:forge && npm run contract:preflight:sw13:nova",
    "contract:drift:hard": "node scripts/sw08/check-contract-drift.js --baseline api/artifacts/contracts/baseline-contract-artifact.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/drift-report.json --mode hard-fail",
    "contract:gate:hard": "node scripts/sw08/check-contract-drift.js --baseline api/artifacts/contracts/baseline-contract-artifact.json --current api/artifacts/contracts/contract-artifact.json --report api/artifacts/contracts/drift-report.json --mode hard-fail",
    "contract:gate:hard:approved": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw08/drift-old.json --current test/fixtures/sw08/drift-new.json --report api/artifacts/contracts/stage3-approved-report.json --mode hard-fail --exception test/fixtures/sw08/approved-exception.json",
    "contract:gate:hard:expired": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw08/drift-old.json --current test/fixtures/sw08/drift-new.json --report api/artifacts/contracts/stage3-expired-report.json --mode hard-fail --exception test/fixtures/sw08/expired-exception.json",
    "contract:gate:hard:missing-approval": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw08/drift-old.json --current test/fixtures/sw08/drift-new.json --report api/artifacts/contracts/stage3-missing-approval-report.json --mode hard-fail --exception test/fixtures/sw08/missing-approval-exception.json",
    "contract:compat-check:hard": "node scripts/sw08/check-contract-drift.js --baseline test/fixtures/sw08/compat-old.json --current test/fixtures/sw08/compat-new.json --report api/artifacts/contracts/stage3-compat-report.json --mode hard-fail",
    "contract:metrics:weekly": "node scripts/sw08/report-contract-metrics.js --reports-dir api/artifacts/contracts --report api/artifacts/contracts/sw08-trend-report.json --weekly-days 7 --rolling-days 30",
    "contract:metrics:trend:strict": "node scripts/sw08/report-contract-metrics.js --reports-dir api/artifacts/contracts --report api/artifacts/contracts/sw08-trend-report.json --weekly-days 7 --rolling-days 30 --fail-on-recurrence",
    "contract:check:stage3": "npm run contract:artifact && npm run contract:gate:hard && node scripts/sw08/write-contract-safety-gate-report.js --drift api/artifacts/contracts/drift-report.json --out reports/sw-08-contract-safety-gate/report.md --stage stage3",
    "contract:check:stage5": "npm run contract:check:stage3 && npm run contract:metrics:trend:strict && node scripts/sw08/write-contract-safety-gate-report.js --drift api/artifacts/contracts/drift-report.json --trend api/artifacts/contracts/sw08-trend-report.json --out reports/sw-08-contract-safety-gate/report.md --stage stage5",
    "contract:pr:hygiene": "node scripts/sw08/check-pr-contract-hygiene.js --changed-files api/artifacts/contracts/sw08-changed-files.txt",
    "security:audit": "npm audit --audit-level=high"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qagwaai/solid-train.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/qagwaai/solid-train/issues"
  },
  "homepage": "https://github.com/qagwaai/solid-train#readme",
  "dependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^10.4.1",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2"
}
