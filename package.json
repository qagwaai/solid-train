{
  "name": "solid-train",
  "version": "1.0.0",
  "description": "Simple Socket.IO server with Node.js best practices",
  "main": "src/server.js",
  "scripts": {
    "test": "node --test",
    "start": "cross-env MONGODB_URI=mongodb://localhost:27017/solid-train node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.checkjs.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qagwaai/solid-train.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/qagwaai/solid-train/issues"
  },
  "homepage": "https://github.com/qagwaai/solid-train#readme",
  "dependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "mongoose": "^8.24.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "mongodb-memory-server": "^11.1.0",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
