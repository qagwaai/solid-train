{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ship-upsert-request",
  "type": "object",
  "required": [
    "playerName",
    "characterId",
    "sessionKey",
    "correlationId",
    "requestIdentity",
    "ship"
  ],
  "properties": {
    "playerName": { "type": "string" },
    "characterId": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Client-generated UUID v4 used to correlate each request/response pair."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "ship": {
      "type": "object",
      "description": "Partial ship patch object. Nested patch intent is determined by property presence. When ship.inventory is present, the server applies the provided inventory patch. When ship.inventory is omitted, the server preserves existing ship inventory references.",
      "properties": {
        "inventory": {
          "type": "array",
          "description": "Optional inventory patch for the target ship. Presence indicates patch intent; omission preserves the current ship inventory references. Entries may be canonical ShipItem rows (`id`, `itemType`, `displayName`), compact references (`itemId`, `itemType`), or hydrated rows (`id`, `itemType`).",
          "items": {
            "type": "object",
            "oneOf": [
              {
                "required": ["id", "itemType", "displayName"],
                "properties": {
                  "id": { "type": "string" },
                   "itemType": { "$ref": "./canonical-item-type.schema.json" },
                  "displayName": { "type": "string" }
                }
              },
              {
                "required": ["itemId", "itemType"],
                "properties": {
                  "itemId": { "type": "string" },
                   "itemType": { "$ref": "./canonical-item-type.schema.json" }
                }
              },
              {
                "required": ["id", "itemType"],
                "properties": {
                  "id": { "type": "string" },
                   "itemType": { "$ref": "./canonical-item-type.schema.json" }
                }
              }
            ],
            "additionalProperties": true
          }
        },
        "damageProfile": {
          "type": "object",
          "description": "Optional damage profile patch. Presence indicates patch intent for damage profile fields."
        },
        "ownership": {
          "type": "object",
          "description": "Optional ownership patch. Presence indicates ownership transfer/update intent.",
          "required": ["ownerType"],
          "properties": {
            "ownerType": {
              "type": "string",
              "enum": ["player-character", "npc-pirate", "unowned", "unknown"]
            },
            "playerId": { "type": ["string", "null"] },
            "characterId": { "type": ["string", "null"] },
            "npcId": { "type": ["string", "null"] },
            "factionId": { "type": ["string", "null"] },
            "claimToken": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
