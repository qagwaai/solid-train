{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "market-quote-request",
  "type": "object",
  "required": [
    "playerName",
    "characterId",
    "sessionKey",
    "correlationId",
    "requestIdentity",
    "marketId",
    "solarSystemId",
    "itemId",
    "direction",
    "quantity"
  ],
  "properties": {
    "playerName": { "type": "string" },
    "characterId": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Client-generated UUID v4 used to correlate each request/response pair."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "marketId": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "itemId": { "type": "string" },
    "direction": { "type": "string" },
    "quantity": { "type": "integer" },
    "requestId": { "type": "string" }
  }
}
