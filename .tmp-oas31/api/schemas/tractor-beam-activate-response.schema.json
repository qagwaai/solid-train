{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "tractor-beam-activate-response",
  "type": "object",
  "required": [
    "success",
    "message",
    "correlationId",
    "requestIdentity",
    "playerName",
    "characterId",
    "shipId",
    "targetItemId",
    "targetCelestialBodyId"
  ],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Echo of the request correlationId."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "playerName": { "type": "string" },
    "characterId": { "type": "string" },
    "shipId": { "type": "string" },
    "tractorBeamItemId": { "type": "string" },
    "targetItemId": { "type": ["string", "null"] },
    "targetCelestialBodyId": { "type": ["string", "null"] },
    "activated": { "type": "boolean" }
  }
}
