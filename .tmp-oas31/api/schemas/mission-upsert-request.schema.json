{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mission-upsert-request",
  "type": "object",
  "required": [
    "playerName",
    "characterId",
    "missionId",
    "sessionKey",
    "status",
    "correlationId",
    "requestIdentity"
  ],
  "properties": {
    "playerName": { "type": "string" },
    "characterId": { "type": "string" },
    "missionId": {
      "type": "string",
      "description": "Canonical mission id. Must be one of the mission ids known to the server mission catalog."
    },
    "sessionKey": { "type": "string" },
    "status": {
      "type": "string",
      "description": "Mission board status lane value.",
      "enum": ["available", "active", "completed"]
    },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Client-generated UUID v4 used to correlate each request/response pair."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "requestId": {
      "type": "string",
      "description": "Optional request correlation id echoed in the response when provided."
    }
  }
}
