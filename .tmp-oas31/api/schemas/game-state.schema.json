{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "game-state",
  "type": "object",
  "required": ["playerName", "sessionKey", "characterId", "state"],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "characterId": { "type": "string" },
    "state": { "type": "object" },
    "asOf": { "type": "string", "format": "date-time" }
  }
}
