{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "item-list-by-owner-request",
  "type": "object",
  "required": ["playerName", "sessionKey", "owner"],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": { "type": "string" },
    "owner": {
      "type": "object",
      "required": ["ownerType"],
      "properties": {
        "ownerType": {
          "type": "string",
          "enum": ["player-character", "npc-pirate", "unowned", "unknown"]
        },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
