{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "market-offer-create-request",
  "type": "object",
  "required": [
    "playerName",
    "sessionKey",
    "correlationId",
    "requestIdentity",
    "listingId",
    "offerorOwner",
    "offerPrice",
    "quantity"
  ],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": { "type": "string" },
    "requestIdentity": {
      "type": "object",
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "listingId": { "type": "string" },
    "offerorOwner": {
      "type": "object",
      "required": ["ownerType"],
      "properties": {
        "ownerType": {
          "type": "string",
          "enum": ["player-character", "npc-pirate", "unowned", "unknown"]
        },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "offerPrice": { "type": "number", "minimum": 0 },
    "quantity": { "type": "integer", "minimum": 1 }
  },
  "additionalProperties": true
}
