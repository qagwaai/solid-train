{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ship-transfer-request",
  "type": "object",
  "required": ["playerName", "sessionKey", "correlationId", "requestIdentity", "shipId", "fromOwner", "toOwner"],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Client-generated UUID v4 used to correlate each request/response pair."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "shipId": { "type": "string" },
    "claimToken": { "type": ["string", "null"] },
    "transferReason": { "type": ["string", "null"] },
    "actorCharacterId": { "type": ["string", "null"] },
    "fromOwner": {
      "type": "object",
      "required": ["ownerType"],
      "properties": {
        "ownerType": {
          "type": "string",
          "enum": ["player-character", "npc-pirate", "unowned", "unknown"]
        },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "toOwner": {
      "type": "object",
      "required": ["ownerType"],
      "properties": {
        "ownerType": {
          "type": "string",
          "enum": ["player-character", "npc-pirate", "unowned", "unknown"]
        },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  }
}
