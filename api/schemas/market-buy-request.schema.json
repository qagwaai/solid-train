{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "market-buy-request",
  "type": "object",
  "required": [
    "playerName",
    "sessionKey",
    "correlationId",
    "requestIdentity",
    "marketId",
    "solarSystemId",
    "characterId",
    "itemId",
    "quantity"
  ],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Client-generated UUID v4 used to correlate each request/response pair."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "marketId": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "characterId": { "type": "string" },
    "itemId": {
      "type": "string",
      "description": "Catalog or market inventory item id. The server normalizes matching case-insensitively."
    },
    "quantity": {
      "type": "integer",
      "minimum": 1,
      "description": "Requested buy quantity. Must be a positive integer."
    },
    "requestId": {
      "type": "string",
      "description": "Optional caller correlation id echoed in the response."
    },
    "transactionId": {
      "type": "string",
      "description": "Optional caller-supplied transaction id. If omitted, the server creates one."
    }
  }
}
