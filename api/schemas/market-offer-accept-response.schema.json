{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "market-offer-accept-response",
  "type": "object",
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "reason": {
      "type": "string",
      "enum": [
        "INVALID_SESSION",
        "OFFER_NOT_FOUND",
        "LISTING_NOT_FOUND",
        "OWNERSHIP_VALIDATION_FAILED",
        "OWNERSHIP_ACCEPT_FORBIDDEN"
      ]
    },
    "correlationId": { "type": "string" },
    "requestIdentity": {
      "type": "object",
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "offerId": { "type": "string" },
    "listingId": { "type": "string" },
    "tradeId": { "type": "string" },
    "completedAt": { "type": "string" },
    "tradeHistory": {
      "type": "object",
      "properties": {
        "at": { "type": "string" },
        "offerId": { "type": "string" },
        "listingOwner": {
          "type": "object",
          "properties": {
            "ownerType": { "type": "string" },
            "playerId": { "type": ["string", "null"] },
            "characterId": { "type": ["string", "null"] },
            "npcId": { "type": ["string", "null"] },
            "factionId": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "offerorOwner": {
          "type": "object",
          "properties": {
            "ownerType": { "type": "string" },
            "playerId": { "type": ["string", "null"] },
            "characterId": { "type": ["string", "null"] },
            "npcId": { "type": ["string", "null"] },
            "factionId": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        },
        "acceptorCharacterId": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
