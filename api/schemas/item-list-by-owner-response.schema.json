{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "item-list-by-owner-response",
  "type": "object",
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "reason": {
      "type": "string",
      "enum": [
        "INVALID_SESSION",
        "OWNERSHIP_VALIDATION_FAILED",
        "ITEM_LIST_OWNER_FORBIDDEN"
      ]
    },
    "correlationId": { "type": "string" },
    "owner": {
      "type": "object",
      "properties": {
        "ownerType": { "type": "string" },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "items": {
      "type": "array",
      "items": { "$ref": "./item.schema.json" }
    }
  },
  "additionalProperties": true
}
