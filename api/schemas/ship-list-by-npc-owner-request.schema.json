{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ship-list-by-npc-owner-request",
  "type": "object",
  "required": ["playerName", "sessionKey", "npcOwner"],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": { "type": "string" },
    "npcOwner": {
      "type": "object",
      "required": ["ownerType", "npcId"],
      "properties": {
        "ownerType": {
          "type": "string",
          "enum": ["npc-pirate"]
        },
        "npcId": { "type": "string" },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
