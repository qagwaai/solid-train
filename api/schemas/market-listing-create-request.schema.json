{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "market-listing-create-request",
  "type": "object",
  "required": [
    "playerName",
    "sessionKey",
    "correlationId",
    "requestIdentity",
    "marketId",
    "solarSystemId",
    "itemId",
    "quantity",
    "owner",
    "listingPrice"
  ],
  "properties": {
    "playerName": { "type": "string" },
    "sessionKey": { "type": "string" },
    "correlationId": { "type": "string" },
    "requestIdentity": {
      "type": "object",
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "marketId": { "type": "string" },
    "solarSystemId": { "type": "string" },
    "itemId": { "type": "string" },
    "quantity": { "type": "integer", "minimum": 1 },
    "listingPrice": { "type": "number", "minimum": 0 },
    "expiresInMinutes": { "type": ["integer", "null"], "minimum": 1 },
    "owner": {
      "type": "object",
      "required": ["ownerType"],
      "properties": {
        "ownerType": {
          "type": "string",
          "enum": ["player-character", "npc-pirate", "unowned", "unknown"]
        },
        "playerId": { "type": ["string", "null"] },
        "characterId": { "type": ["string", "null"] },
        "npcId": { "type": ["string", "null"] },
        "factionId": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
