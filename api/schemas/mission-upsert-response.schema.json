{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mission-upsert-response",
  "type": "object",
  "required": [
    "success",
    "message",
    "playerName",
    "characterId",
    "correlationId",
    "requestIdentity"
  ],
  "properties": {
    "success": { "type": "boolean" },
    "message": { "type": "string" },
    "playerName": { "type": "string" },
    "characterId": { "type": "string" },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Echo of the request correlationId."
    },
    "requestIdentity": {
      "type": "object",
      "required": ["operation", "entityType", "containerId"],
      "properties": {
        "operation": { "type": "string" },
        "entityType": { "type": "string" },
        "containerId": { "type": "string" }
      }
    },
    "mission": {
      "type": "object",
      "description": "Present on successful mission upsert responses.",
      "properties": {
        "missionId": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["available", "active", "completed"]
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["missionId", "status"],
      "additionalProperties": false
    },
    "requestId": {
      "type": "string",
      "description": "Echoed caller correlation id when one was supplied on the request."
    }
  }
}
